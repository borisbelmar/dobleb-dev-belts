---
import { cn } from '../lib/utils';

interface Props {
  tags: string[];
  class?: string;
}

const { tags, class: className } = Astro.props;
---

{tags.length > 0 && (
  <div class={cn('flex flex-wrap gap-2', className)}>
    {tags.map((tag) => (
      <a
        href={`/tag/${tag}`}
        class="font-mono text-xs text-terminal-dim bg-terminal-darker px-2 py-0.5 hover:text-terminal-green transition-colors"
      >
        {tag}
      </a>
    ))}
  </div>
)}

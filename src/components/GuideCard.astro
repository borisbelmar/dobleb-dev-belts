---
import { cn } from '../lib/utils';

interface Props {
  title: string;
  description: string;
  tags: string[];
  href: string;
  class?: string;
}

const { title, description, tags, href, class: className } = Astro.props;
---

<a
  href={href}
  class={cn(
    'block bg-terminal-dark border border-terminal-dim p-6 transition-all',
    'hover:border-terminal-green hover:shadow-[0_0_12px_rgba(0,255,65,0.15)] hover:-translate-y-0.5',
    className,
  )}
>
  <h3 class="font-sans font-semibold text-lg text-terminal-white mb-2">{title}</h3>
  <p class="text-terminal-gray text-sm leading-relaxed mb-4">{description}</p>
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="font-mono text-xs text-terminal-dim bg-terminal-darker px-2 py-0.5">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>

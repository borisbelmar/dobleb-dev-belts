---
import BaseLayout from '../layouts/BaseLayout.astro';
import GuideCard from '../components/GuideCard.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const guides = await getCollection('guides');

  const beltData = {
    'white-belt': { label: 'White Belt', description: 'Fundamentos esenciales de programación', name: 'Level 01' },
    'yellow-belt': { label: 'Yellow Belt', description: 'La Web y las APIs', name: 'Level 02' },
    'green-belt': { label: 'Green Belt', description: 'Aplicaciones Fullstack', name: 'Level 03' },
    'black-belt': { label: 'Black Belt', description: 'Arquitectura y Operaciones', name: 'Level 04' },
  };

  return Object.keys(beltData).map((slug) => {
    const beltGuides = guides
      .filter((g) => g.data.belt === slug && g.data.published !== false)
      .sort((a, b) => a.data.order - b.data.order);

    return {
      params: { belt: slug },
      props: {
        belt: slug,
        label: beltData[slug as keyof typeof beltData].label,
        description: beltData[slug as keyof typeof beltData].description,
        name: beltData[slug as keyof typeof beltData].name,
        guides: beltGuides,
        allBelts: beltData,
      },
    };
  });
}) satisfies GetStaticPaths;

const { belt, label, description, name, guides } = Astro.props;
---

<BaseLayout title={`${label} — devBelts`} description={description} currentPath={`/${belt}`}>
  <header class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 relative">
    <div class="font-mono text-terminal-gray text-sm tracking-widest uppercase mb-2">{name}</div>
    <h1 class="glitch font-mono text-3xl sm:text-4xl font-bold text-terminal-white tracking-tight mb-3" data-text={label}>{label}</h1>
    <p class="text-terminal-gray text-lg">{description}</p>
    <div class="absolute bottom-4 left-4 font-mono text-xs text-terminal-dim">{guides.length} {guides.length === 1 ? 'guía' : 'guías'}</div>
  </header>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {guides.map((guide) => (
        <GuideCard
          title={guide.data.title}
          description={guide.data.description}
          tags={guide.data.tags}
          href={`/guides/${guide.id}`}
        />
      ))}
    </div>
  </section>
</BaseLayout>

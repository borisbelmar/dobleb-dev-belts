---
import BaseLayout from '../layouts/BaseLayout.astro';
import GuideCard from '../components/GuideCard.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const guides = await getCollection('guides');

  const beltData = {
    'white-belt': { label: 'White Belt', description: 'Fundamentos esenciales de programación', name: 'Level 01' },
    'yellow-belt': { label: 'Yellow Belt', description: 'La Web y las APIs', name: 'Level 02' },
    'green-belt': { label: 'Green Belt', description: 'Aplicaciones Fullstack', name: 'Level 03' },
    'black-belt': { label: 'Black Belt', description: 'Arquitectura y Operaciones', name: 'Level 04' },
  };

  return Object.keys(beltData).map((slug) => {
    const beltGuides = guides
      .filter((g) => g.data.belt === slug && g.data.published !== false)
      .sort((a, b) => a.data.order - b.data.order);

    return {
      params: { belt: slug },
      props: {
        belt: slug,
        label: beltData[slug as keyof typeof beltData].label,
        description: beltData[slug as keyof typeof beltData].description,
        name: beltData[slug as keyof typeof beltData].name,
        guides: beltGuides,
        allBelts: beltData,
      },
    };
  });
}) satisfies GetStaticPaths;

const { belt, label, description, name, guides, allBelts } = Astro.props;
---

<BaseLayout title={`${label} — devBelts`} description={description} currentPath={`/${belt}`}>
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-4">
    <div class="flex flex-wrap gap-2">
      {Object.entries(allBelts).map(([slug, data]) => {
        const isActive = slug === belt;
        const dot = slug === 'white-belt' ? 'bg-white border border-gray-600'
          : slug === 'yellow-belt' ? 'bg-yellow-500'
          : slug === 'green-belt' ? 'bg-green-500'
          : 'bg-gray-900 border border-gray-600';

        const common = `inline-flex items-center gap-1.5 px-2.5 py-1 text-xs font-mono border rounded`;

        return isActive ? (
          <span class={`${common} bg-terminal-dark border-terminal-green text-terminal-green`}>
            <span class={`w-2 h-2 rounded-full ${dot}`}></span>
            {data.name} · {data.label.split(' ')[0]}
          </span>
        ) : (
          <a
            href={`/${slug}`}
            class={`${common} bg-terminal-dark border-terminal-dim text-terminal-gray hover:border-terminal-green hover:text-terminal-green transition-colors`}
          >
            <span class={`w-2 h-2 rounded-full ${dot}`}></span>
            {data.name} · {data.label.split(' ')[0]}
          </a>
        );
      })}
    </div>
  </nav>

  <header class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 relative">
    <div class="font-mono text-terminal-gray text-sm tracking-widest uppercase mb-2">
      {name} — {guides.length} {guides.length === 1 ? 'Guía' : 'Guías'}
    </div>
    <h1 class="glitch font-mono text-3xl sm:text-4xl font-bold text-terminal-white tracking-tight mb-3" data-text={label}>{label}</h1>
    <p class="text-terminal-gray text-lg">{description}</p>
  </header>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {guides.map((guide) => (
        <GuideCard
          title={guide.data.title}
          description={guide.data.description}
          tags={guide.data.tags}
          lastRevision={guide.data.lastRevision}
          href={`/guides/${guide.id}`}
        />
      ))}
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import BeltCard from '../components/BeltCard.astro';
import { getCollection } from 'astro:content';

const guides = await getCollection('guides');

const beltCounts: Record<string, number> = {
  'white-belt': 0,
  'yellow-belt': 0,
  'green-belt': 0,
  'black-belt': 0,
};

for (const guide of guides) {
  if (guide.data.published !== false) {
    beltCounts[guide.data.belt] = (beltCounts[guide.data.belt] || 0) + 1;
  }
}

const belts: { name: string; label: string; slug: 'white-belt' | 'yellow-belt' | 'green-belt' | 'black-belt'; description: string }[] = [
  {
    name: 'Level 01',
    label: 'White Belt',
    slug: 'white-belt',
    description: 'Fundamentos esenciales de programación',
  },
  {
    name: 'Level 02',
    label: 'Yellow Belt',
    slug: 'yellow-belt',
    description: 'La Web y las APIs',
  },
  {
    name: 'Level 03',
    label: 'Green Belt',
    slug: 'green-belt',
    description: 'Aplicaciones Fullstack',
  },
  {
    name: 'Level 04',
    label: 'Black Belt',
    slug: 'black-belt',
    description: 'Arquitectura y Operaciones',
  },
];
---

<BaseLayout title="devBelts" description="Guías de programación organizadas en 4 niveles tipo cinturones. Aprende. Practica. Domina.">
  <header class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
    <div class="space-y-6">
      <div class="font-mono text-terminal-dim text-sm tracking-widest uppercase">
        <span class="text-terminal-green">&gt;</span> initializing learning sequence...
      </div>
      <h1 class="font-mono text-4xl sm:text-5xl lg:text-6xl font-bold text-terminal-white tracking-tight">
        devBelts
      </h1>
      <p class="text-xl sm:text-2xl text-terminal-gray max-w-2xl leading-relaxed">
        Guías de programación organizadas en 4 niveles tipo cinturones.
        <span class="text-terminal-green">Aprende. Practica. Domina.</span>
      </p>
    </div>
  </header>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="font-mono text-2xl sm:text-3xl font-semibold text-terminal-white mb-8 tracking-tight">
      Belt Levels
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {belts.map((belt) => (
        <BeltCard
          name={belt.name}
          label={belt.label}
          description={belt.description}
          count={beltCounts[belt.slug]}
          belt={belt.slug}
          href={`/${belt.slug}`}
        />
      ))}
    </div>
  </section>
</BaseLayout>
